# ══════════════════════════════════════
# 滇界云管 · 环境变量模板
# 复制为 .env 后填入实际值
# ══════════════════════════════════════

# 数据库（本地开发用 localhost，生产用阿里云 RDS）
DATABASE_URL="postgresql://dianjie:your_password@localhost:5432/dianjie?connection_limit=10&pool_timeout=20"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# 服务端口
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development

# 前端 API 地址
NEXT_PUBLIC_API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# 企业微信 Webhook（可选，填入后启用推送）
WECHAT_WEBHOOK_URL=

# Sentry 监控（可选，填入 DSN 后启用）
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# 阿里云 OSS（文件上传）
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# ══════════════════════════════════════
# 招商银行新直联（免前置） · 国密微服务（dianjie-v4-cmb）
# 文档: docs/cmb/2026-05-13-招行BB1PAY-报文规范.md
# 生产值从 ~/Desktop/免前置Demo/云洱密钥.txt 注入（禁止入 git）
# ══════════════════════════════════════
CMB_USE_PROD=false                                # true=生产 https://cdc.cmbchina.com / false=测试
CMB_URL=                                          # 留空走默认（测试 cdctest.cmburl.cn / 生产 cdc.cmbchina.com）
CMB_UID=U005182425                                # 测试 UID；生产改成银行下发的生产 UID
CMB_ACCOUNT=655905978110000                       # 付款结算账户号
CMB_PRIVATE_KEY=                                  # 用户 SM2 私钥（生产必须重新生成）
CMB_PUBLIC_KEY=                                   # 用户 SM2 公钥（生产对应私钥）
CMB_BANK_PUBLIC_KEY=                              # 银行 SM2 公钥（测试/生产不同, 见云洱密钥.txt）
CMB_SYM_KEY=                                      # SM4 对称密钥 16 字节
CMB_BUSMOD=S100B                                  # 支付业务模式（DCLISMOD self-check 后定）
CMB_BUSCOD=N02030                                 # 业务代码
CMB_CCY_NBR=10                                    # 货币码 10=RMB
CMB_SERVICE_PORT=5001                             # Flask 微服务监听端口
CMB_SERVICE_URL=http://localhost:5001             # Node 客户端调用地址
